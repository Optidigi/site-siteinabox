---
import '../styles/global.css';
import Seo from '../components/seo/Seo.astro';
import JsonLdOrganization from '../components/seo/JsonLdOrganization.astro';
import JsonLdLocalBusiness from '../components/seo/JsonLdLocalBusiness.astro';
import { site } from '../content/site';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, ogImage, noindex } = Astro.props;
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#481938" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="generator" content={Astro.generator} />
    <Seo title={title} description={description} ogImage={ogImage} noindex={noindex} />
    <JsonLdOrganization />
    <JsonLdLocalBusiness />

    <!-- Legacy Piku theme stylesheets (preserved for visual fidelity) -->
    <link rel="stylesheet" href="/legacy/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/legacy/assets/css/style.css" />
    <link rel="stylesheet" href="/legacy/assets/css/responsive.css" />
    <link rel="stylesheet" href="/legacy/assets/css/siab-overrides.css" />

    <!-- Trimmed Google Fonts: only the families actually rendered by .font-test-familjen + .font-Playfair -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;500;600;700;900&family=Familjen+Grotesk:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
    />
  </head>
  <body class="font-test-familjen">
    <div class="main-page-wrapper">
      <slot />
    </div>

    <!-- Sticky header (.theme-main-menu.sticky-menu → .fixed past 180px scroll).
         Inlined so the scroll listener is wired up before the user can possibly
         scroll past the threshold — defers theme.js late-binding leaves a window
         where the .fixed class is applied late, making the background-fade
         transition start mid-scroll instead of at the trigger point. -->
    <script is:inline>
      (function () {
        var menu = document.querySelector('.sticky-menu');
        if (!menu) return;
        var onScroll = function () {
          if (window.scrollY >= 180) menu.classList.add('fixed');
          else menu.classList.remove('fixed');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <!-- Vanilla replacements for Bootstrap Collapse + Tab. Attaches at HTML
         parse time (no waiting for deferred scripts) — no click-buffer needed.
         Matches Bootstrap-bundle's data-api semantics including height
         animation (.collapsing → .collapse.show), data-bs-parent
         single-open accordion behavior, and `.fade.show.active` tab classes. -->
    <script is:inline>
      (function () {
        // ---------- Collapse (mobile nav + FAQ accordion) ----------
        function onTransitionEnd(el, cb) {
          var done = function (e) {
            if (e && e.target !== el) return; // ignore bubbled events from children
            el.removeEventListener('transitionend', done);
            clearTimeout(fallback);
            cb();
          };
          // Fallback in case transitionend doesn't fire (scrollHeight=0 etc.)
          var fallback = setTimeout(function () { done(); }, 400);
          el.addEventListener('transitionend', done);
        }
        function expand(el) {
          el.classList.remove('collapse');
          el.classList.add('collapsing');
          el.style.height = '0px';
          // Two rAFs guarantee a paint between the initial height and the
          // target height, so the browser actually runs the CSS transition.
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              onTransitionEnd(el, function () {
                el.classList.remove('collapsing');
                el.classList.add('collapse', 'show');
                el.style.height = '';
              });
              el.style.height = el.scrollHeight + 'px';
            });
          });
        }
        function collapseEl(el) {
          el.style.height = el.scrollHeight + 'px';
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              el.classList.remove('collapse', 'show');
              el.classList.add('collapsing');
              onTransitionEnd(el, function () {
                el.classList.remove('collapsing');
                el.classList.add('collapse');
                el.style.height = '';
              });
              el.style.height = '0px';
            });
          });
        }
        function findSiblings(el) {
          // data-bs-parent="#id" enables single-open accordion semantics
          var pSel = el.getAttribute('data-bs-parent');
          if (!pSel) return [];
          var parent = document.querySelector(pSel);
          if (!parent) return [];
          return Array.prototype.slice.call(
            parent.querySelectorAll('.accordion-collapse.show')
          ).filter(function (other) { return other !== el; });
        }
        function buttonsFor(el) {
          // All toggle buttons pointing at this collapse element
          return document.querySelectorAll(
            '[data-bs-toggle="collapse"][data-bs-target="#' + el.id + '"], ' +
            '[data-bs-toggle="collapse"][href="#' + el.id + '"]'
          );
        }
        function syncButtonState(el, open) {
          buttonsFor(el).forEach(function (btn) {
            btn.setAttribute('aria-expanded', String(open));
            btn.classList.toggle('collapsed', !open);
          });
        }

        // ---------- Tab (pricing M/J) ----------
        function showTab(btn) {
          var sel = btn.getAttribute('data-bs-target') || btn.getAttribute('href');
          var pane = sel && document.querySelector(sel);
          if (!pane) return;
          // Find sibling tabs (in same .nav-tabs / .nav) and sibling panes (in same .tab-content)
          var tablist = btn.closest('[role="tablist"]') || btn.closest('.nav-tabs') || btn.closest('.nav');
          var paneParent = pane.closest('.tab-content') || pane.parentElement;
          if (tablist) {
            tablist.querySelectorAll('[data-bs-toggle="tab"], .nav-link').forEach(function (t) {
              t.classList.remove('active');
              t.setAttribute('aria-selected', 'false');
            });
          }
          if (paneParent) {
            paneParent.querySelectorAll('.tab-pane').forEach(function (p) {
              p.classList.remove('show', 'active');
            });
          }
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          pane.classList.add('show', 'active');
        }

        document.addEventListener('click', function (e) {
          var collapseBtn = e.target.closest('[data-bs-toggle="collapse"]');
          if (collapseBtn) {
            e.preventDefault();
            var sel = collapseBtn.getAttribute('data-bs-target') || collapseBtn.getAttribute('href');
            var el = sel && document.querySelector(sel);
            if (!el) return;
            var isOpen = el.classList.contains('show');
            if (isOpen) {
              collapseEl(el);
              syncButtonState(el, false);
            } else {
              // Single-open accordion: close siblings first
              findSiblings(el).forEach(function (other) {
                collapseEl(other);
                syncButtonState(other, false);
              });
              expand(el);
              syncButtonState(el, true);
            }
            return;
          }
          var tabBtn = e.target.closest('[data-bs-toggle="tab"]');
          if (tabBtn) {
            e.preventDefault();
            showTab(tabBtn);
          }
        });
      })();
    </script>

    <!-- Vendor JS — only what's still required (jQuery for Slick, Slick for
         the testimonial carousel, Lottie player for the hero rocket).
         Bootstrap-bundle was dropped: collapse + tab are handled in the inline
         script above, tooltips are pure CSS (siab-overrides.css).
         WOW + theme.js were dropped earlier this commit. -->
    <script is:inline defer src="/legacy/assets/vendor/jquery.min.js"></script>
    <script is:inline defer src="/legacy/assets/vendor/slick/slick.min.js"></script>
    <script is:inline defer src="/legacy/assets/vendor/lottie-player.min.js"></script>

    <!-- Slick init + reduced-motion Lottie + slick aria-hidden-focus fix -->
    <script is:inline>
      window.addEventListener('load', function () {
        if (window.jQuery && window.jQuery.fn.slick) {
          window.jQuery('.feedback-slider-six').slick({
            dots: false,
            arrows: true,
            prevArrow: window.jQuery('.prev_b'),
            nextArrow: window.jQuery('.next_b'),
            lazyLoad: 'ondemand',
            centerPadding: '0px',
            slidesToShow: 3,
            slidesToScroll: 1,
            centerMode: true,
            autoplay: true,
            autoplaySpeed: 10000,
            responsive: [
              { breakpoint: 768, settings: { slidesToShow: 2 } },
              { breakpoint: 576, settings: { slidesToShow: 1 } },
            ],
          });
        }
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.querySelectorAll('lottie-player').forEach(function (el) {
            el.removeAttribute('autoplay');
            el.removeAttribute('loop');
            if (typeof el.stop === 'function') el.stop();
          });
        }
        var stripSlickTabindex = function () {
          document.querySelectorAll('[data-slick-index][aria-hidden="true"]').forEach(function (el) {
            el.setAttribute('tabindex', '-1');
            el.querySelectorAll('[tabindex]').forEach(function (child) {
              child.setAttribute('tabindex', '-1');
            });
          });
        };
        stripSlickTabindex();
        if (window.jQuery) {
          window.jQuery('.feedback-slider-six').on('afterChange setPosition', stripSlickTabindex);
        }
      });
    </script>
  </body>
</html>
