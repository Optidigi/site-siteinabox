---
import { site } from '../../content/site';

interface Props {
  fallbackHeading?: string;
}

const { fallbackHeading } = Astro.props;

const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const fallbackEmail = import.meta.env.PUBLIC_CONTACT_EMAIL ?? site.nap?.email ?? 'info@siteinabox.nl';

const useWeb3Forms = Boolean(web3FormsKey);
---

<section class="siab-contact-form-section" aria-labelledby={fallbackHeading ? 'siab-contact-form-heading' : undefined}>
  {fallbackHeading && (
    <h2 id="siab-contact-form-heading" class="visually-hidden">{fallbackHeading}</h2>
  )}

  {useWeb3Forms ? (
    <>
      <form
        class="siab-contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
        data-siab-form
        aria-describedby="siab-form-required-hint"
      >
        <p id="siab-form-required-hint" class="visually-hidden">Velden met een sterretje zijn verplicht.</p>

        <input type="hidden" name="access_key" value={web3FormsKey} />
        <input type="hidden" name="from_name" value={site.brand} />
        <input type="hidden" name="subject" value={`Nieuw bericht via ${site.primaryDomain}`} />

        <div class="siab-form-summary" role="alert" hidden data-siab-summary>
          Er ging iets mis. Controleer de gemarkeerde velden hieronder.
        </div>

        <div class="siab-field" data-siab-field>
          <label for="siab-name">Je naam <span aria-hidden="true">*</span></label>
          <input id="siab-name" name="name" type="text" autocomplete="name" required aria-required="true" aria-describedby="siab-name-err" />
          <p id="siab-name-err" class="siab-error" data-siab-error data-empty="Vul je naam in zodat we weten met wie we praten."></p>
        </div>

        <div class="siab-field" data-siab-field>
          <label for="siab-email">E-mailadres <span aria-hidden="true">*</span></label>
          <input id="siab-email" name="email" type="email" autocomplete="email" required aria-required="true" aria-describedby="siab-email-err" />
          <p id="siab-email-err" class="siab-error" data-siab-error data-empty="Vul je e-mailadres in zodat we kunnen antwoorden." data-invalid="Dit lijkt geen geldig e-mailadres. Controleer 'm even."></p>
        </div>

        <div class="siab-field" data-siab-field>
          <label for="siab-message">Je bericht <span aria-hidden="true">*</span></label>
          <textarea id="siab-message" name="message" rows="6" required aria-required="true" aria-describedby="siab-message-err"></textarea>
          <p id="siab-message-err" class="siab-error" data-siab-error data-empty="Schrijf even kort waar je bericht over gaat."></p>
        </div>

        <div class="siab-field siab-field--consent" data-siab-field>
          <label for="siab-consent" class="siab-consent-label">
            <input id="siab-consent" name="consent" type="checkbox" required aria-required="true" aria-describedby="siab-consent-err" />
            <span>Ik ga akkoord dat Site in a Box mijn bericht en e-mailadres gebruikt om mij te antwoorden. <a href="/privacy-policy">Zie ons privacybeleid</a>.</span>
          </label>
          <p id="siab-consent-err" class="siab-error" data-siab-error data-empty="Vink dit aan om je bericht te kunnen versturen."></p>
        </div>

        <input type="checkbox" name="botcheck" class="siab-honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input type="hidden" name="loadedAt" data-siab-loaded-at value="" />

        <div class="siab-submit-row">
          <button type="submit" class="btn-eighteen siab-submit">Verstuur bericht</button>
          <p class="siab-alt-line m0">
            Liever direct mailen? <a href={`mailto:${fallbackEmail}`} class="siab-see-how">{fallbackEmail}</a>
          </p>
        </div>
      </form>

      <div class="siab-success" role="status" aria-live="polite" tabindex="-1" hidden data-siab-success>
        <h2>Bedankt voor je bericht.</h2>
        <p>We hebben je bericht ontvangen en komen er zo snel mogelijk op terug. Hou je e-mail in de gaten.</p>
      </div>
    </>
  ) : fallbackEmail ? (
    <div class="siab-mailto-card">
      <p class="siab-mailto-lead m0">Het online formulier komt binnenkort beschikbaar. Stuur ons in de tussentijd een mail:</p>
      <a href={`mailto:${fallbackEmail}`} class="btn-eighteen siab-mailto-cta">Mail naar {fallbackEmail}</a>
    </div>
  ) : (
    <p class="siab-form-unavailable">Het contactformulier is op dit moment niet beschikbaar.</p>
  )}
</section>

<style>
  .siab-contact-form-section {
    background: #fff;
    border: 2px solid #000;
    border-radius: 0;
    padding: clamp(24px, 4vw, 48px);
    box-shadow: 5px 5px #000;
    width: 100%;
    height: 100%;
  }

  .siab-contact-form { display: block; }

  .siab-field { display: block; margin-bottom: 22px; }
  .siab-field:last-of-type { margin-bottom: 28px; }

  .siab-field > label {
    display: block;
    margin-bottom: 8px;
    font-family: 'Familjen Grotesk', sans-serif;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: #000;
  }

  .siab-field input[type='text'],
  .siab-field input[type='email'],
  .siab-field textarea {
    width: 100%;
    min-height: 56px;
    padding: 14px 18px;
    background: #fff;
    color: #000;
    border: 2px solid #000;
    border-radius: 0;
    font-family: 'Chivo', sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.4;
    transition: box-shadow .12s, transform .12s;
  }

  .siab-field textarea { min-height: 160px; resize: vertical; }

  .siab-field input::placeholder,
  .siab-field textarea::placeholder { color: #00000080; }

  .siab-field input:focus-visible,
  .siab-field textarea:focus-visible {
    outline: 3px solid #000;
    outline-offset: 3px;
  }

  .siab-field[data-siab-invalid] input,
  .siab-field[data-siab-invalid] textarea { border-color: var(--siab-form-err, #c8102e); }
  .siab-field[data-siab-invalid] > label { color: var(--siab-form-err, #c8102e); }

  .siab-error {
    display: none;
    margin: 8px 0 0;
    color: var(--siab-form-err, #c8102e);
    font-family: 'Chivo', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.4;
  }
  .siab-field[data-siab-invalid] .siab-error { display: block; }

  .siab-field--consent .siab-consent-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: 'Chivo', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.55;
    color: #000000cc;
    cursor: pointer;
    margin-bottom: 0;
  }
  .siab-field--consent input[type='checkbox'] {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 2px;
    border: 2px solid #000;
    border-radius: 0;
    accent-color: #f5e900;
    cursor: pointer;
  }
  .siab-field--consent input[type='checkbox']:focus-visible {
    outline: 3px solid #000;
    outline-offset: 3px;
  }
  .siab-field--consent a { color: #000; text-decoration: underline 2px dashed #5a504b; text-underline-offset: 3px; }
  .siab-field--consent a:hover { text-decoration-color: #1a1a1a; }

  .siab-form-summary {
    border: 2px solid var(--siab-form-err, #c8102e);
    background: #fef2f4;
    padding: 12px 16px;
    margin-bottom: 22px;
    color: var(--siab-form-err, #c8102e);
    font-family: 'Chivo', sans-serif;
    font-weight: 600;
    font-size: 15px;
  }

  .siab-submit-row {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .siab-submit { min-width: 220px; }
  .siab-alt-line {
    font-family: 'Chivo', sans-serif;
    font-size: 15px;
    color: #5a504b;
  }

  .siab-honeypot {
    position: absolute !important;
    left: -9999px !important;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .siab-success:focus-visible { outline: none; }
  .siab-success h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin: 0 0 16px;
    color: #000;
  }
  .siab-success p {
    margin: 0;
    font-family: 'Gordita', sans-serif;
    font-size: 18px;
    line-height: 1.65;
    color: #000000bf;
  }

  .siab-mailto-card { padding: 4px 0; }
  .siab-mailto-lead {
    font-family: 'Chivo', sans-serif;
    font-size: 17px;
    color: #000;
    margin-bottom: 20px !important;
  }
  .siab-mailto-cta { display: inline-block; }

  .siab-form-unavailable {
    font-family: 'Chivo', sans-serif;
    font-size: 15px;
    color: #5a504b;
    margin: 0;
  }

  @media (max-width: 575px) {
    .siab-contact-form-section { padding: 20px; box-shadow: 4px 4px #000; }
    .siab-submit { width: 100%; }
    .siab-submit-row { gap: 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .siab-field input[type='text'],
    .siab-field input[type='email'],
    .siab-field textarea { transition: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('[data-siab-form]') as HTMLFormElement | null;
    if (!form) return;

    const loadedAtInput = form.querySelector<HTMLInputElement>('[data-siab-loaded-at]');
    const loadedAt = Date.now();
    if (loadedAtInput) loadedAtInput.value = String(loadedAt);

    const summary = form.querySelector<HTMLElement>('[data-siab-summary]');
    const success = document.querySelector<HTMLElement>('[data-siab-success]');

    const fields = Array.from(form.querySelectorAll<HTMLElement>('[data-siab-field]'));

    const setInvalid = (fieldEl: HTMLElement, errKey: 'empty' | 'invalid') => {
      const errP = fieldEl.querySelector<HTMLElement>('[data-siab-error]');
      if (errP) {
        const msg = errP.dataset[errKey] ?? errP.dataset.empty ?? '';
        errP.textContent = msg;
      }
      fieldEl.setAttribute('data-siab-invalid', '');
      const input = fieldEl.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
      if (input) input.setAttribute('aria-invalid', 'true');
    };

    const clearInvalid = (fieldEl: HTMLElement) => {
      fieldEl.removeAttribute('data-siab-invalid');
      const input = fieldEl.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
      if (input) input.removeAttribute('aria-invalid');
    };

    const validateField = (fieldEl: HTMLElement): boolean => {
      const input = fieldEl.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
      if (!input) return true;
      if ((input as HTMLInputElement).type === 'checkbox') {
        const box = input as HTMLInputElement;
        if (box.required && !box.checked) {
          setInvalid(fieldEl, 'empty');
          return false;
        }
        clearInvalid(fieldEl);
        return true;
      }
      if (input.required && input.value.trim() === '') {
        setInvalid(fieldEl, 'empty');
        return false;
      }
      if ((input as HTMLInputElement).type === 'email' && input.value.trim() !== '') {
        const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim());
        if (!ok) {
          setInvalid(fieldEl, 'invalid');
          return false;
        }
      }
      clearInvalid(fieldEl);
      return true;
    };

    fields.forEach((fieldEl) => {
      const input = fieldEl.querySelector<HTMLInputElement | HTMLTextAreaElement>('input, textarea');
      if (!input) return;
      input.addEventListener('blur', () => validateField(fieldEl));
      input.addEventListener('input', () => {
        if (fieldEl.hasAttribute('data-siab-invalid')) validateField(fieldEl);
      });
      if ((input as HTMLInputElement).type === 'checkbox') {
        input.addEventListener('change', () => {
          if (fieldEl.hasAttribute('data-siab-invalid')) validateField(fieldEl);
        });
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let firstInvalid: HTMLElement | null = null;
      let valid = true;
      for (const fieldEl of fields) {
        const ok = validateField(fieldEl);
        if (!ok) {
          valid = false;
          if (!firstInvalid) firstInvalid = fieldEl;
        }
      }
      if (!valid) {
        if (summary) summary.hidden = false;
        if (firstInvalid) {
          const input = firstInvalid.querySelector<HTMLElement>('input, textarea');
          input?.focus();
        }
        return;
      }
      if (summary) summary.hidden = true;

      if (Date.now() - loadedAt < 3000) return;

      const hp = form.querySelector<HTMLInputElement>('.siab-honeypot');
      if (hp && hp.checked) return;

      const submitBtn = form.querySelector<HTMLButtonElement>('.siab-submit');
      const originalLabel = submitBtn?.textContent ?? 'Verstuur bericht';
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Versturen…';
      }

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, { method: 'POST', body: data });
        if (!res.ok) throw new Error('submit-failed');
        form.hidden = true;
        if (success) {
          success.hidden = false;
          success.focus();
        }
      } catch {
        if (summary) {
          summary.hidden = false;
          summary.textContent = 'Versturen lukte niet. Probeer het zo opnieuw, of stuur een mail naar info@siteinabox.nl.';
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      }
    });
  });
</script>
